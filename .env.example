# ===========================================
# Inlight Agency OS - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# --- Supabase ---
# Get from: https://supabase.com/dashboard/project/[ref]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-cron-secret-token

# --- OAuth / Integrations ---
# Google (Gmail)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Facebook / Instagram
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# Calendly (optional)
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret

# YouTube (uses same Google OAuth credentials as Gmail — enable YouTube Data API v3)
# Enable at: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
# Add these OAuth scopes: youtube.upload, youtube, youtube.readonly
# YouTube uses GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from above

# --- Content Factory API Keys ---
# Unsplash (required for stock photos in content factory)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Pexels (required for stock photos in content factory)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# NewsAPI (required for market research + content ideation)
# Get from: https://newsapi.org/register
NEWSAPI_API_KEY=your-newsapi-api-key

# --- AI Provider ---
# OpenRouter (primary AI — 200+ models, free tier available)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_DEFAULT_MODEL=cohere/north-mini-code:free

# --- Email Delivery ---
# Resend (email delivery for proposals, invoices, support, marketing)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# --- Automation Providers ---
# Paddle (payment processing — Stripe alternative, works in Pakistan)
PADDLE_API_KEY=pdl_live_apikey_your-paddle-key

# HubSpot (CRM — use Private App token starting with pat-)
# Create at: https://app.hubspot.com/private-apps
HUBSPOT_API_KEY=pat-na2-your-hubspot-private-app-token

# Calendly (scheduling — uses OAuth)
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret

# Salesforce (CRM — OAuth + client_credentials)
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret

# Slack (messaging)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Discord (messaging)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Telegram (messaging)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Airtable (databases)
AIRTABLE_API_KEY=your-airtable-api-key

# n8n (workflow automation — self-hosted)
N8N_API_KEY=your-n8n-api-key
N8N_BASE_URL=http://localhost:5678

# make.com (scenario automation)
MAKE_API_KEY=your-make-api-key
MAKE_BASE_URL=https://eu1.make.com

# ─── Observability ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
